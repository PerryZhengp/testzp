        <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="Assertion - keepalive expected result" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">import groovy.json.JsonSlurper
def label = prev.getSampleLabel()
def body = prev.getResponseDataAsString()
if (prev.getResponseCode() == '500' || body.contains('NullPointerException') || body.contains('Cannot invoke')) {
  AssertionResult.setFailure(true)
  AssertionResult.setFailureMessage('Server exception during keepalive flow: ' + label)
  return
}
def code = null
try { code = new JsonSlurper().parseText(body)?.code } catch (Exception ignore) {}
if (label.contains('[EXPECT_OK]') &amp;&amp; code != 0) {
  AssertionResult.setFailure(true)
  AssertionResult.setFailureMessage('Expected success but failed: ' + label + ' code=' + code)
}
if (label.contains('[EXPECT_FAIL]') &amp;&amp; code == 0) {
  AssertionResult.setFailure(true)
  AssertionResult.setFailureMessage('Expected failure but got success: ' + label)
}</stringProp>
        </JSR223Assertion>
        <hashTree/>
      </hashTree>

