            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Parse - dynamic question ids" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="script">import groovy.json.JsonSlurper
def txt = prev.getResponseDataAsString()
def root = new JsonSlurper().parseText(txt)
def contentText = root?.data?.content
if (!contentText) return
def inner = new JsonSlurper().parseText(contentText)
def gap = inner?.blocks?.find { it.type == 'GapFilling' }
def single = inner?.blocks?.find { it.type == 'SingleChoice' }
if (gap) {
  vars.put('gapQuestionId', gap.id?.toString() ?: '')
  def inputIds = gap?.data?.items?.findAll { it.type == 'input' }?.collect { it.id?.toString() }?.findAll { it } ?: []
  vars.put('gapInputIdsCsv', inputIds.join(','))
}
if (single) {
  vars.put('singleQuestionId', single.id?.toString() ?: '')
  vars.put('singleChoiceReference', single?.data?.settings?.reference?.toString() ?: '')
}</stringProp>
            </JSR223PostProcessor>
