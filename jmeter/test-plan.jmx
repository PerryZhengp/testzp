          <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="Header - auth" enabled="true"><collectionProp name="HeaderManager.headers"><elementProp name="Authorization" elementType="Header"><stringProp name="Header.name">Authorization</stringProp><stringProp name="Header.value">${authPrefix}${accessToken}</stringProp></elementProp></collectionProp></HeaderManager>
          <hashTree/>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Parse question ids - perf answer" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">import groovy.json.JsonSlurper
def txt = prev.getResponseDataAsString()
def root = new JsonSlurper().parseText(txt)
def contentText = root?.data?.content
if (!contentText) return
def inner = new JsonSlurper().parseText(contentText)
def gap = inner?.blocks?.find { it.type == 'GapFilling' }
def single = inner?.blocks?.find { it.type == 'SingleChoice' }
if (gap) {
  vars.put('gapQuestionId', gap.id?.toString() ?: '')
  def inputIds = gap?.data?.items?.findAll { it.type == 'input' }?.collect { it.id?.toString() }?.findAll { it } ?: []
  vars.put('gapInputIdsCsv', inputIds.join(','))
}
if (single) {
  vars.put('singleQuestionId', single.id?.toString() ?: '')
  vars.put('singleChoiceReference', single?.data?.settings?.reference?.toString() ?: '')
}</stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>

        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="PERF-004-saveQuestionAnswer" enabled="true">
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument"><boolProp name="HTTPArgument.always_encode">false</boolProp><stringProp name="Argument.value">${saveQuestionAnswerBody}</stringProp><stringProp name="Argument.metadata">=</stringProp></elementProp>
            </collectionProp>
          </elementProp>
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <stringProp name="HTTPSampler.path">/api/admin/nexalapi/exp/v1/saveQuestionAnswer</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
        </HTTPSamplerProxy>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Build questionAnswerList - perf focus" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">import groovy.json.JsonOutput
def username = vars.get('username') ?: 'unknown'
def seed = username + '_' + ctx.getThreadNum() + '_' + vars.getIteration() + '_' + System.currentTimeMillis()
def rnd = new Random((seed.hashCode() as long) ^ System.nanoTime())
def min = Integer.parseInt((props['answer.min'] ?: '1'))
def max = Integer.parseInt((props['answer.max'] ?: '9999'))
def nextNumber = { -&gt; (rnd.nextInt(max - min + 1) + min).toString() }
def gapSubtitleIds = [
  (props['answer.fallback.gap.subtitle.id1'] ?: 'ribcrlV6xK'),
  (props['answer.fallback.gap.subtitle.id2'] ?: 'Uv9NC4virf'),
  (props['answer.fallback.gap.subtitle.id3'] ?: 'lHBYTCtXty')
].collect { it?.toString()?.trim() }.findAll { it }
if (!gapSubtitleIds) {
  gapSubtitleIds = ['ribcrlV6xK', 'Uv9NC4virf', 'lHBYTCtXty']
}
def targetCount = Math.max(gapSubtitleIds.size(), 3)
def lastSignature = vars.get('lastAnswerSignaturePerf') ?: ''
def signature = ''
def gapSubtitleAnswerList = []
int guard = 0
while (true) {
  guard++
  def randomValues = []
  def seen = [] as Set
  while (randomValues.size() &lt; targetCount) {
    def candidate = nextNumber()
    if (seen.add(candidate) || seen.size() &gt;= (max - min + 1)) {
      randomValues &lt;&lt; candidate
    }
  }
  gapSubtitleAnswerList = []
  gapSubtitleIds.eachWithIndex { sid, idx -&gt;
    gapSubtitleAnswerList &lt;&lt; [subtitleId: sid, subtitleAnswer: randomValues[idx % randomValues.size()]]
  }
  signature = gapSubtitleAnswerList.collect { item -&gt; "${item.subtitleId}:${item.subtitleAnswer}" }.join('|')
  if (signature != lastSignature || guard &gt;= 8) {
    break
  }
}
vars.put('lastAnswerSignaturePerf', signature)
vars.put('answerSignature', signature)
def singleBlockId = vars.get('singleQuestionId') ?: (props['answer.fallback.single.blockId'] ?: 'oaXh7gOyKt')
def singleAnswer = vars.get('singleChoiceReference') ?: (props['answer.fallback.single.choice'] ?: 'uD2mKpkAmc')
def singleSubtitleId = (props['answer.fallback.single.subtitleId'] ?: '')
def gapBlockId = vars.get('gapQuestionId') ?: (props['answer.fallback.gap.blockId'] ?: 'YndHSdJkXa')
def questionAnswerList = [
  [
    blockId: singleBlockId,
    blockType: (props['answer.fallback.single.blockType'] ?: 'SingleChoice'),
    subtitleAnswerList: [[subtitleId: singleSubtitleId, subtitleAnswer: singleAnswer]]
  ],
  [
    blockId: gapBlockId,
    blockType: (props['answer.fallback.gap.blockType'] ?: 'GapFilling'),
    subtitleAnswerList: gapSubtitleAnswerList
  ]
]
def payload = [
  userReportId: vars.get('dynamicUserReportId'),
  questionAnswerList: questionAnswerList
]
vars.put('saveQuestionAnswerBody', JsonOutput.toJson(payload))</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
