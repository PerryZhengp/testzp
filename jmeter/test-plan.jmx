      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="TG-04 Perf-Login-Focus" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Perf Login Loop Controller" enabled="true">
          <boolProp name="LoopController.continue_forever">true</boolProp>
          <stringProp name="LoopController.loops">-1</stringProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">${__groovy((props.get('run.profile','all') in ['all','perf_login']) ? props.get('perf.login.threads','8') : '0',)}</stringProp>
        <stringProp name="ThreadGroup.ramp_time">${__P(perf.login.rampup,10)}</stringProp>
        <boolProp name="ThreadGroup.scheduler">true</boolProp>
        <stringProp name="ThreadGroup.duration">${__P(perf.login.duration.seconds,300)}</stringProp>
        <stringProp name="ThreadGroup.delay">0</stringProp>
        <longProp name="ThreadGroup.start_time">1710000000000</longProp>
        <longProp name="ThreadGroup.end_time">1710000000000</longProp>
      </ThreadGroup>
