          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Resolve - effectiveUserReportId" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">def dynamicId = (vars.get('dynamicUserReportId') ?: '').trim()
def mappedId = (vars.get('mappedUserReportId') ?: '').trim()
def effective = dynamicId ? dynamicId : mappedId
