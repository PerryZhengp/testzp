        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="EX-CrossAccount-saveQuestionAnswer [EXPECT_FAIL]" enabled="true">
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">${crossSaveQuestionAnswerBody}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <stringProp name="HTTPSampler.path">/api/admin/nexalapi/exp/v1/saveQuestionAnswer</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
        </HTTPSamplerProxy>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Build - cross account answer body" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">import groovy.json.JsonOutput
def rnd = new Random(System.nanoTime())
def min = Integer.parseInt((props['answer.min'] ?: '1'))
def max = Integer.parseInt((props['answer.max'] ?: '9999'))
def nextNumber = { -&gt; (rnd.nextInt(max - min + 1) + min).toString() }
def a1 = nextNumber()
def a2 = nextNumber()
while (a2 == a1) a2 = nextNumber()
def a3 = nextNumber()
while (a3 == a1 || a3 == a2) a3 = nextNumber()
def questionAnswerList = [
  [
    blockId: (props['answer.fallback.single.blockId'] ?: 'oaXh7gOyKt'),
    blockType: (props['answer.fallback.single.blockType'] ?: 'SingleChoice'),
    subtitleAnswerList: [[
      subtitleId: (props['answer.fallback.single.subtitleId'] ?: ''),
      subtitleAnswer: (props['answer.fallback.single.choice'] ?: 'uD2mKpkAmc')
    ]]
  ],
  [
    blockId: (props['answer.fallback.gap.blockId'] ?: 'YndHSdJkXa'),
    blockType: (props['answer.fallback.gap.blockType'] ?: 'GapFilling'),
    subtitleAnswerList: [
      [subtitleId: (props['answer.fallback.gap.subtitle.id1'] ?: 'ribcrlV6xK'), subtitleAnswer: a1],
      [subtitleId: (props['answer.fallback.gap.subtitle.id2'] ?: 'Uv9NC4virf'), subtitleAnswer: a2],
      [subtitleId: (props['answer.fallback.gap.subtitle.id3'] ?: 'lHBYTCtXty'), subtitleAnswer: a3]
    ]
  ]
]
def payload = [
  userReportId: vars.get('crossUserReportId'),
  questionAnswerList: questionAnswerList
]
vars.put('crossSaveQuestionAnswerBody', JsonOutput.toJson(payload))
def recordPayload = [
  courseId: vars.get('courseId'),
  teachingTaskId: vars.get('teachingTaskId'),
  blockId: vars.get('blockId'),
  userReportId: vars.get('crossUserReportId'),
  answerRecord: JsonOutput.toJson([questionAnswerList: questionAnswerList, ts: System.currentTimeMillis()])
]
vars.put('crossSaveExpAnswerRecordBody', JsonOutput.toJson(recordPayload))</stringProp>
