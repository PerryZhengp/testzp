        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="INIT - mixed vars" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">vars.put('courseId', (props['courseId'] ?: '2032055666142167042'))
vars.put('teachingTaskId', (props['teachingTaskId'] ?: '2033505568785190913'))
vars.put('blockId', (props['blockId'] ?: '3O00nCpPKp'))
