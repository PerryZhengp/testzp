              </collectionProp>
            </elementProp>
            <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
            <stringProp name="HTTPSampler.path">/api/admin/nexalapi/exp/v1/saveQuestionAnswer</stringProp>
