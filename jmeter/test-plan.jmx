            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Build mixed random subtitleanswer" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="script">import groovy.json.JsonOutput
def username = vars.get('username') ?: 'unknown'
def seed = username + '_' + ctx.getThreadNum() + '_' + vars.getIteration() + '_' + System.currentTimeMillis()
def rnd = new Random((seed.hashCode() as long) ^ System.nanoTime())
def a = (rnd.nextInt(89) + 10).toString()
def b = (rnd.nextInt(89) + 10).toString()
def c = (rnd.nextInt(89) + 10).toString()
def subtitle = [sub1:a, sub2:b, sub3:c]
def payload = [
  courseId: vars.get('courseId'),
  teachingTaskId: vars.get('teachingTaskId'),
  blockId: vars.get('blockId'),
  userReportId: vars.get('dynamicUserReportId'),
  questionId: props.get('answer.fallback.questionId', 'YndHSdJkXa'),
  answer: subtitle.values().join('|'),
  subtitleanswer: subtitle
]
