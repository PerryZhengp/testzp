          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Build - cross account answer body" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">import groovy.json.JsonOutput
def rnd = new Random(System.nanoTime())
def a1 = (rnd.nextInt(89) + 10).toString()
def a2 = (rnd.nextInt(89) + 10).toString()
def a3 = (rnd.nextInt(89) + 10).toString()
def subtitle = [sub1:a1, sub2:a2, sub3:a3]
def payload = [
  courseId: vars.get('courseId'),
  teachingTaskId: vars.get('teachingTaskId'),
  blockId: vars.get('blockId'),
  userReportId: vars.get('crossUserReportId'),
  questionId: props.get('answer.fallback.questionId', 'YndHSdJkXa'),
  answer: subtitle.values().join('|'),
  subtitleanswer: subtitle
]
vars.put('crossSaveQuestionAnswerBody', JsonOutput.toJson(payload))
def recordPayload = [
  courseId: vars.get('courseId'),
  teachingTaskId: vars.get('teachingTaskId'),
  blockId: vars.get('blockId'),
  userReportId: vars.get('crossUserReportId'),
  answerRecord: JsonOutput.toJson([subtitleanswer: subtitle, ts: System.currentTimeMillis()])
]
vars.put('crossSaveExpAnswerRecordBody', JsonOutput.toJson(recordPayload))</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
          <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="Header - auth cross" enabled="true"><collectionProp name="HeaderManager.headers"><elementProp name="Authorization" elementType="Header"><stringProp name="Header.name">Authorization</stringProp><stringProp name="Header.value">${authPrefix}${accessToken}</stringProp></elementProp></collectionProp></HeaderManager>
