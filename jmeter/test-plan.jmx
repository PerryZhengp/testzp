        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="INIT - Load Mapping &amp; Runtime Vars" enabled="true">
          <stringProp name="cacheKey">functional-init</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">import java.nio.file.Files
import java.nio.file.Paths
import java.nio.charset.StandardCharsets

def map = props.get('accountReportMap')
if (map == null) {
  map = [:]
  def mappingPath = (props['mapping.file'] ?: 'jmeter/data/account_report_mapping.csv')
  def fullPath = Paths.get(mappingPath)
  if (!fullPath.isAbsolute()) {
    fullPath = Paths.get(System.getProperty('user.dir')).resolve(mappingPath)
  }
  if (Files.exists(fullPath)) {
    Files.readAllLines(fullPath, StandardCharsets.UTF_8).drop(1).each { line ->
      if (!line?.trim()) return
      def arr = line.split(',', 2)
      def u = arr[0].trim()
      def r = arr.length &gt; 1 ? arr[1].trim() : ''
      map[u] = r
    }
  }
  props.put('accountReportMap', map)
}

vars.put('courseId', (props['courseId'] ?: '2032055666142167042'))
vars.put('teachingTaskId', (props['teachingTaskId'] ?: '2033505568785190913'))
vars.put('blockId', (props['blockId'] ?: '3O00nCpPKp'))
vars.put('authPrefix', (props['auth.prefix'] ?: 'Bearer '))
vars.put('clientKeyHeader', (props['clientKey'] ?: 'test-client'))
vars.put('clientVersionHeader', (props['clientVersion'] ?: 'V1.0'))

def username = vars.get('username') ?: ''
def mapped = map[username] ?: ''
vars.put('mappedUserReportId', mapped)
vars.put('dynamicUserReportId', '')
vars.put('effectiveUserReportId', mapped)
def cross = map.find { k, v -> k != username &amp;&amp; v }
vars.put('crossUserReportId', cross ? cross.value.toString() : '')</stringProp>
        </JSR223Sampler>
