          <hashTree/>
          <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="Assert - perf answer no 500" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">if (prev.getResponseCode() == '500') {
  AssertionResult.setFailure(true)
  AssertionResult.setFailureMessage('HTTP 500 in perf answer sampler')
}</stringProp>
          </JSR223Assertion>
          <hashTree/>
        </hashTree>
