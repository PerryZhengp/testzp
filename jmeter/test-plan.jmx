          <stringProp name="HTTPSampler.path">/admin/nexalapi/resource/v1/queryExpGuidebookContent?courseId=${courseId}&amp;teachingTaskId=${teachingTaskId}&amp;blockId=${blockId}&amp;userReportId=${dynamicUserReportId}</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
        </HTTPSamplerProxy>
        <hashTree>
          <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="Header - auth" enabled="true"><collectionProp name="HeaderManager.headers"><elementProp name="Authorization" elementType="Header"><stringProp name="Header.name">Authorization</stringProp><stringProp name="Header.value">${authPrefix}${accessToken}</stringProp></elementProp></collectionProp></HeaderManager>
          <hashTree/>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Parse question ids - perf answer" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">import groovy.json.JsonSlurper
def txt = prev.getResponseDataAsString()
def root = new JsonSlurper().parseText(txt)
def contentText = root?.data?.content
if (!contentText) return
def inner = new JsonSlurper().parseText(contentText)
def gap = inner?.blocks?.find { it.type == 'GapFilling' }
if (gap) {
  vars.put('gapQuestionId', gap.id?.toString() ?: '')
  def inputIds = gap?.data?.items?.findAll { it.type == 'input' }?.collect { it.id?.toString() }?.findAll { it } ?: []
  vars.put('gapInputIdsCsv', inputIds.join(','))
}</stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>

        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="PERF-Answer-saveQuestionAnswer" enabled="true">
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument"><boolProp name="HTTPArgument.always_encode">false</boolProp><stringProp name="Argument.value">${saveQuestionAnswerBody}</stringProp><stringProp name="Argument.metadata">=</stringProp></elementProp>
            </collectionProp>
          </elementProp>
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <stringProp name="HTTPSampler.path">/admin/nexalapi/exp/v1/saveQuestionAnswer</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
        </HTTPSamplerProxy>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Build random subtitleanswer - perf focus" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">import groovy.json.JsonOutput
def username = vars.get('username') ?: 'unknown'
def seed = username + '_' + ctx.getThreadNum() + '_' + vars.getIteration() + '_' + System.currentTimeMillis()
def rnd = new Random((seed.hashCode() as long) ^ System.nanoTime())
def min = Integer.parseInt(props.get('answer.min', '1'))
def max = Integer.parseInt(props.get('answer.max', '99'))
def nextNumber = { -&gt; (rnd.nextInt(max - min + 1) + min).toString() }
def n1 = nextNumber(); def n2 = nextNumber(); def n3 = nextNumber()
while (n2 == n1) n2 = nextNumber()
while (n3 == n1 || n3 == n2) n3 = nextNumber()
def values = [n1, n2, n3]
def ids = (vars.get('gapInputIdsCsv') ?: '').split(',').findAll { it?.trim() }
def subtitle = [:]
if (ids) {
  ids.eachWithIndex { id, idx -&gt; subtitle[id] = values[idx % values.size()] }
  vars.put('questionIdForAnswer', vars.get('gapQuestionId') ?: props.get('answer.fallback.questionId', 'YndHSdJkXa'))
} else {
  subtitle[props.get('answer.fallback.subtitle.key1', 'sub1')] = n1
  subtitle[props.get('answer.fallback.subtitle.key2', 'sub2')] = n2
  subtitle[props.get('answer.fallback.subtitle.key3', 'sub3')] = n3
  vars.put('questionIdForAnswer', props.get('answer.fallback.questionId', 'YndHSdJkXa'))
}
vars.put('subtitleanswer', JsonOutput.toJson(subtitle))
def payload = [
  courseId: vars.get('courseId'),
  teachingTaskId: vars.get('teachingTaskId'),
  blockId: vars.get('blockId'),
  userReportId: vars.get('dynamicUserReportId'),
  questionId: vars.get('questionIdForAnswer'),
  answer: subtitle.values().join('|'),
  subtitleanswer: subtitle
]
vars.put('saveQuestionAnswerBody', JsonOutput.toJson(payload))</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
