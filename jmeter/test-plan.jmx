          <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="Assert - Login token not empty" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">if (!prev.getResponseCode().startsWith('2')) {
  AssertionResult.setFailure(true)
  AssertionResult.setFailureMessage('Login HTTP status is not 2xx: ' + prev.getResponseCode())
}
def body = prev.getResponseDataAsString()
if (body.contains('NullPointerException') || body.contains('Cannot invoke')) {
  AssertionResult.setFailure(true)
  AssertionResult.setFailureMessage('Server exception signature found in login response')
}
if (!(vars.get('accessToken') ?: '').trim()) {
  AssertionResult.setFailure(true)
  AssertionResult.setFailureMessage('accessToken is empty after login')
}</stringProp>
          </JSR223Assertion>
