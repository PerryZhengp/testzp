        <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="Assertion - exception expected pass/fail contract" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">import groovy.json.JsonSlurper
def label = prev.getSampleLabel()
def body = prev.getResponseDataAsString()
if (prev.getResponseCode() == '500' || body.contains('NullPointerException') || body.contains('Cannot invoke') || body.contains('java.lang')) {
  AssertionResult.setFailure(true)
  AssertionResult.setFailureMessage('Server exception signature detected in exception scenario: ' + label)
  return
}
def code = null
try { code = new JsonSlurper().parseText(body)?.code } catch (Exception ignore) {}
if (label.contains('[EXPECT_FAIL]') &amp;&amp; code == 0) {
  AssertionResult.setFailure(true)
  AssertionResult.setFailureMessage('Expected business failure but got success: ' + label)
}
if (label.contains('[EXPECT_OK]') &amp;&amp; code != 0) {
  AssertionResult.setFailure(true)
  AssertionResult.setFailureMessage('Expected success but got business failure: ' + label + ' code=' + code)
}</stringProp>
        </JSR223Assertion>
        <hashTree/>
      </hashTree>

