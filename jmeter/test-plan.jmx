                </elementProp>
              </collectionProp>
            </elementProp>
            <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
            <stringProp name="HTTPSampler.path">/admin/nexalapi/exp/v1/saveQuestionAnswer</stringProp>
            <stringProp name="HTTPSampler.method">POST</stringProp>
          </HTTPSamplerProxy>
          <hashTree>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Build payload - Random unique subtitleanswer (dynamic+fallback)" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="script">import groovy.json.JsonOutput
def username = vars.get('username') ?: 'unknown'
def seed = username + '_' + ctx.getThreadNum() + '_' + vars.getIteration() + '_' + System.currentTimeMillis()
def rnd = new Random((seed.hashCode() as long) ^ System.nanoTime())
def min = Integer.parseInt(props.get('answer.min', '1'))
def max = Integer.parseInt(props.get('answer.max', '99'))
def nextNumber = { -&gt; (rnd.nextInt(max - min + 1) + min).toString() }
def n1 = nextNumber()
def n2 = nextNumber()
def n3 = nextNumber()
while (n2 == n1) { n2 = nextNumber() }
while (n3 == n1 || n3 == n2) { n3 = nextNumber() }
def values = [n1, n2, n3]
def subtitleMap = [:]
def mode = (props.get('answer.payload.mode', 'hybrid') ?: 'hybrid').toLowerCase()
def ids = (vars.get('gapInputIdsCsv') ?: '').split(',').findAll { it?.trim() }
def useDynamic = (mode == 'dynamic' || mode == 'hybrid') &amp;&amp; ids
if (useDynamic) {
  ids.eachWithIndex { id, idx -&gt; subtitleMap[id] = values[idx % values.size()] }
  vars.put('questionIdForAnswer', vars.get('gapQuestionId') ?: props.get('answer.fallback.questionId', 'YndHSdJkXa'))
} else {
  subtitleMap[props.get('answer.fallback.subtitle.key1', 'sub1')] = n1
  subtitleMap[props.get('answer.fallback.subtitle.key2', 'sub2')] = n2
  subtitleMap[props.get('answer.fallback.subtitle.key3', 'sub3')] = n3
  vars.put('questionIdForAnswer', props.get('answer.fallback.questionId', 'YndHSdJkXa'))
}
def subtitleJson = JsonOutput.toJson(subtitleMap)
vars.put('subtitleanswer', subtitleJson)
vars.put('subtitleanswerSeed', seed)
def answerValue = subtitleMap.values().join('|')
vars.put('answer', answerValue)
def payload = [
  courseId: vars.get('courseId'),
  teachingTaskId: vars.get('teachingTaskId'),
  blockId: vars.get('blockId'),
  userReportId: vars.get('effectiveUserReportId'),
  questionId: vars.get('questionIdForAnswer'),
  answer: answerValue,
  subtitleanswer: subtitleMap
]
vars.put('saveQuestionAnswerBody', JsonOutput.toJson(payload))
def recordPayload = [
  courseId: vars.get('courseId'),
  teachingTaskId: vars.get('teachingTaskId'),
  blockId: vars.get('blockId'),
  userReportId: vars.get('effectiveUserReportId'),
  answerRecord: JsonOutput.toJson([
    subtitleanswer: subtitleMap,
    seed: seed,
    user: username,
    ts: System.currentTimeMillis()
  ])
]
vars.put('saveExpAnswerRecordBody', JsonOutput.toJson(recordPayload))</stringProp>
            </JSR223PreProcessor>
