          </HTTPSamplerProxy>
          <hashTree>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Build mixed questionAnswerList (fixed subtitleId)" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="script">import groovy.json.JsonOutput
def username = vars.get('username') ?: 'unknown'
def seed = username + '_' + ctx.getThreadNum() + '_' + vars.getIteration() + '_' + System.currentTimeMillis()
def rnd = new Random((seed.hashCode() as long) ^ System.nanoTime())
def min = Integer.parseInt((props['answer.min'] ?: '1'))
def max = Integer.parseInt((props['answer.max'] ?: '9999'))
def nextNumber = { -&gt; (rnd.nextInt(max - min + 1) + min).toString() }
def lastSignature = vars.get('lastAnswerSignatureMixed') ?: ''
def a = ''
def b = ''
def c = ''
def signature = ''
int guard = 0
while (true) {
  guard++
  a = nextNumber()
  b = nextNumber()
  while (b == a) b = nextNumber()
  c = nextNumber()
  while (c == a || c == b) c = nextNumber()
  signature = "${a}|${b}|${c}"
  if (signature != lastSignature || guard &gt;= 8) {
    break
  }
}
vars.put('lastAnswerSignatureMixed', signature)
vars.put('answerSignature', signature)
def questionAnswerList = [
  [
    blockId: (vars.get('singleQuestionId') ?: (props['answer.fallback.single.blockId'] ?: 'oaXh7gOyKt')),
    blockType: (props['answer.fallback.single.blockType'] ?: 'SingleChoice'),
    subtitleAnswerList: [[
      subtitleId: (props['answer.fallback.single.subtitleId'] ?: ''),
      subtitleAnswer: (vars.get('singleChoiceReference') ?: (props['answer.fallback.single.choice'] ?: 'uD2mKpkAmc'))
    ]]
  ],
  [
    blockId: (vars.get('gapQuestionId') ?: (props['answer.fallback.gap.blockId'] ?: 'YndHSdJkXa')),
    blockType: (props['answer.fallback.gap.blockType'] ?: 'GapFilling'),
    subtitleAnswerList: [
      [subtitleId: (props['answer.fallback.gap.subtitle.id1'] ?: 'ribcrlV6xK'), subtitleAnswer: a],
      [subtitleId: (props['answer.fallback.gap.subtitle.id2'] ?: 'Uv9NC4virf'), subtitleAnswer: b],
      [subtitleId: (props['answer.fallback.gap.subtitle.id3'] ?: 'lHBYTCtXty'), subtitleAnswer: c]
    ]
  ]
]
def payload = [
  userReportId: vars.get('dynamicUserReportId'),
  questionAnswerList: questionAnswerList
]
vars.put('saveQuestionAnswerBody', JsonOutput.toJson(payload))
def record = [
  courseId: vars.get('courseId'),
  teachingTaskId: vars.get('teachingTaskId'),
  blockId: vars.get('blockId'),
  userReportId: vars.get('dynamicUserReportId'),
  answerRecord: JsonOutput.toJson([questionAnswerList: questionAnswerList, seed: seed])
]
vars.put('saveExpAnswerRecordBody', JsonOutput.toJson(record))</stringProp>
            </JSR223PreProcessor>
