        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="INIT - exception vars + cross report id" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">import java.nio.file.Files
import java.nio.file.Paths
import java.nio.charset.StandardCharsets
def map = props.getObject('accountReportMap')
if (map == null) {
  map = [:]
  def mappingPath = props.get('mapping.file', 'jmeter/data/account_report_mapping.csv')
  def fullPath = Paths.get(mappingPath)
  if (!fullPath.isAbsolute()) fullPath = Paths.get(System.getProperty('user.dir')).resolve(mappingPath)
  if (Files.exists(fullPath)) {
    Files.readAllLines(fullPath, StandardCharsets.UTF_8).drop(1).each { line -&gt;
      if (!line?.trim()) return
      def arr = line.split(',', 2)
      map[arr[0].trim()] = arr.length &gt; 1 ? arr[1].trim() : ''
    }
  }
  props.putObject('accountReportMap', map)
}
vars.put('courseId', props.get('courseId', '2032055666142167042'))
vars.put('teachingTaskId', props.get('teachingTaskId', '2033505568785190913'))
vars.put('blockId', props.get('blockId', '3O00nCpPKp'))
vars.put('authPrefix', props.get('auth.prefix', 'Bearer '))
vars.put('clientKeyHeader', props.get('clientKey', 'test-client'))
vars.put('clientVersionHeader', props.get('clientVersion', 'V1.0'))
def username = vars.get('username') ?: ''
def mapped = map[username] ?: ''
vars.put('mappedUserReportId', mapped)
def cross = map.find { k, v -> k != username &amp;&amp; v }
vars.put('crossUserReportId', cross ? cross.value.toString() : '')</stringProp>
        </JSR223Sampler>
